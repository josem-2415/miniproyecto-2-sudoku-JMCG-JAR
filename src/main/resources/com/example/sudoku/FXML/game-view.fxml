                        <StackPane prefHeight="150.0" prefWidth="200.0" styleClass="cell" GridPane.columnIndex="4" GridPane.rowIndex="5" />
                        <StackPane prefHeight="150.0" prefWidth="200.0" styleClass="cell" GridPane.columnIndex="5" GridPane.rowIndex="5" />
                     </children>
                  </GridPane>
               </children>
                </VBox>

                <VBox prefWidth="280.0" spacing="25.0">
               <HBox prefHeight="67.0" prefWidth="280.0">
                  <children>
                     <StackPane prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <Button mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" styleClass="utility-button" text="Undo" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <Button mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" styleClass="utility-button" text="Button" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <Button mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" styleClass="utility-button" text="Button" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <Button mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" styleClass="utility-button" text="Button" />
                        </children>
                     </StackPane>
                  </children>
               </HBox>
               <GridPane prefHeight="226.0" prefWidth="225.0" styleClass="sudoku-grid">
                 <columnConstraints>
                     <ColumnConstraints hgrow="SOMETIMES" minWidth="75.0" prefWidth="75.0" />
                   <ColumnConstraints hgrow="SOMETIMES" minWidth="75.0" prefWidth="75.0" />
                   <ColumnConstraints hgrow="SOMETIMES" minWidth="75.0" prefWidth="75.0" />
                 </columnConstraints>
                 <rowConstraints>
                   <RowConstraints minHeight="75.0" prefHeight="75.0" vgrow="SOMETIMES" />
                   <RowConstraints minHeight="75.0" prefHeight="75.0" vgrow="SOMETIMES" />
                   <RowConstraints minHeight="75.0" prefHeight="75.0" vgrow="SOMETIMES" />
                 </rowConstraints>
                  <children>
                     <StackPane prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="1" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="1">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="2" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="2">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="3" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.rowIndex="1">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="4" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="5" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="6" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.rowIndex="2">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="7" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="8" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                     <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="2" GridPane.rowIndex="2">
                        <children>
                           <Button contentDisplay="CENTER" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #cdcdcd;" styleClass="num-button" text="9" textAlignment="CENTER" />
                        </children>
                     </StackPane>
                  </children>
               </GridPane>

                    <Button maxWidth="Infinity" prefHeight="50.0" prefWidth="255.0" style="-fx-background-color: #4e6073; -fx-padding: 15 30; -fx-background-radius: 25;" styleClass="primary-action-button" text="NEW GAME" textFill="WHITE">
                  <font>
                     <Font name="System Bold" size="14.0" />
                  </font></Button>
                </VBox>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
