<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<fx:root prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: #f9f9f9;" stylesheets="@style.css" type="StackPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sudoku.controller.MenuController">
      <VBox alignment="CENTER" maxWidth="350" spacing="30" style="-fx-background-color: #f9f9f9;">
          <padding>
         <Insets bottom="20" left="20" right="20" top="20" />
      </padding>

          <VBox alignment="CENTER" spacing="5">
              <Label styleClass="main-title" text="SUDOKU" />
              <Label styleClass="subtitle" text="THE MATHEMATICAL SANCTUARY" />
          </VBox>

          <VBox fillWidth="true" spacing="12">
              <Button fx:id="btnPlay" maxWidth="Infinity" onAction="#initialize" style="-fx-background-color: #4e6073; -fx-background-radius: 50; -fx-padding: 15 30;" text="NEW GAME" textFill="WHITE">
            <font>
               <Font name="System Bold" size="12.0" />
            </font></Button>
              <Button id="btnExit" fx:id="btnExit" maxWidth="Infinity" onAction="#exitGame" style="-fx-background-color: invisible; -fx-border-radius: 25; -fx-border-width: 3; -fx-border-color: #4e6073; -fx-padding: 15 30;" text="EXIT GAME" textFill="#616161">
            <font>
               <Font name="System Bold" size="12.0" />
            </font></Button>
          </VBox>
      </VBox>
</fx:root>
